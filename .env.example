# Diamond — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to GitHub.

# ── RPC Endpoints ───────────────────────────────────────────────────────────
# Use Alchemy or QuickNode for private RPC (lower latency, no rate limits).
# Public fallbacks are provided but NOT recommended for production.

# Polygon RPC (for Polymarket CLOB signing)
# Alchemy:   https://polygon-mainnet.g.alchemy.com/v2/YOUR-API-KEY
# QuickNode: https://few-white-gas.quiknode.io/YOUR-API-KEY/
# Public:    https://polygon-rpc.com  (not recommended)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_POLYGON_ALCHEMY_KEY

# ── Binance ────────────────────────────────────────────────────────────────
# Required for Futures data + WebSocket stream.
# Create at: https://www.binance.com/en/my/settings/api-management
# Enable: Futures (USDT-M) — Read-Only is sufficient for signal generation.
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── Polymarket ─────────────────────────────────────────────────────────────
# L2 credentials — required for placing orders.
# Get from: https://polymarket.com/api-details
POLYMARKET_PRIVATE_KEY=your_polygon_wallet_private_key_here
POLYMARKET_API_KEY=your_polymarket_api_key_here
POLYMARKET_API_SECRET=your_polymarket_api_secret_here
POLYMARKET_API_PASSPHRASE=your_polymarket_api_passphrase_here
POLYMARKET_CHAIN_ID=137
